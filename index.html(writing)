window.onload = function() {
let menuHtml = '';
restaurantMenu.forEach(section => {
menuHtml += `<h3 class="category-title">${section.category}</h3>`;
section.items.forEach(item => {
menuHtml += `
<div class="menu-row">
<div><h4>${item.name}</h4><p style="color:#666; font-size:0.9rem;">$${item.price.toFixed(2)}</p></div>
<button class="add-btn" onclick="addToCart('${item.name.replace(/'/g, "\\'")}', ${item.price})">+ Add</button>
</div>`;
});
});
document.getElementById('fullMenuContainer').innerHTML = menuHtml;
}

let cart = [];
const TAX_RATE = 0.0825;

function addToCart(name, price) { cart.push({ name, price }); updateCart(); }
function updateCart() {
let html = ''; let subtotal = 0;
if (cart.length === 0) { html = '<p style="font-size:0.9rem; color:#888; font-style:italic;">Your plate is empty.</p>'; }
else {
cart.forEach((item, i) => {
html += `<div class="cart-item"><span>${i+1}. ${item.name}</span><span>$${item.price.toFixed(2)}</span></div>`;
subtotal += item.price;
});
}
document.getElementById('cartList').innerHTML = html;
document.getElementById('total').innerText = (subtotal + (subtotal * TAX_RATE)).toFixed(2);
}

function submitReservation() {
let name = document.getElementById('resName').value;
let phone = document.getElementById('resPhone').value;
let date = document.getElementById('resDate').value;
let time = document.getElementById('resTime').value;
let table = document.getElementById('resTable').value;

if(!name || !phone || !date || !time) { alert("Please fill all reservation details."); return; }

let btn = document.getElementById('submitResBtn');
btn.innerText = "Processing..."; btn.disabled = true;

let dataObj = {
_subject: "Written by the Seasons - New Table Reservation",
Request_Type: "Table Reservation",
Customer_Name: name,
Phone: phone,
Date: date,
Time: time,
Table_Preference: table
};

fetch(FORMSPREE_URL, {
method: "POST",
headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' },
body: JSON.stringify(dataObj)
}).then(response => {
btn.innerHTML = '<i class="fas fa-check"></i> Reservation Confirmed!';
btn.style.background = "#28a745";

setTimeout(() => {
document.getElementById('resName').value = "";
document.getElementById('resPhone').value = "";
document.getElementById('resDate').value = "";
document.getElementById('resTime').value = "";
closeRes();
btn.innerHTML = '<i class="fas fa-check"></i> Confirm Reservation';
btn.style.background = "var(--text-dark)";
btn.disabled = false;
}, 2500);
}).catch(error => {
alert("Something went wrong. Please try again.");
btn.innerHTML = '<i class="fas fa-check"></i> Confirm Reservation';
btn.disabled = false;
});
}

function submitToFormspree() {
if(cart.length === 0) { alert("Please add items to your order first."); return; }

let orderName = document.getElementById('orderName').value;
if(orderName.trim() === "") { alert("Please enter your name."); return; }

let btn = document.getElementById('submitOrderBtn');
btn.innerText = "Processing..."; btn.disabled = true;

let dataObj = {
_subject: "Written by the Seasons - Order from " + orderName,
Request_Type: "Menu Order",
Customer_Name: orderName,
Order_Type: document.getElementById('tableNumber').value,
Items_Ordered: cart.map(item => item.name).join(", "),
Total_Amount: "$" + document.getElementById('total').innerText
};

fetch(FORMSPREE_URL, {
method: "POST",
headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' },
body: JSON.stringify(dataObj)
}).then(response => {
btn.innerHTML = '<i class="fas fa-check"></i> Order sent to kitchen!';
btn.style.background = "#28a745";

setTimeout(() => {
cart = [];
document.getElementById('orderName').value = "";
updateCart(); closeMenu();
