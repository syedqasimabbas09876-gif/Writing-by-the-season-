<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<style>
:root {
--bg-color: #F9F8F6;
--text-dark: #2C2A29;
--accent-copper: #B87333;
--accent-light: #E8DFD5;
--card-bg: #FFFFFF;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
font-family: 'Montserrat', sans-serif;
background-color: var(--bg-color);
color: var(--text-dark);
overflow-x: hidden;
scroll-behavior: smooth;
width: 100%;
}

h1, h2, h3, h4, .serif { font-family: 'Cormorant Garamond', serif; }

/* --- TOP HEADER --- */
.top-header {
background-color: rgba(249, 248, 246, 0.95);
padding: 15px 5%; display: flex; justify-content: space-between; align-items: center;
border-bottom: 1px solid var(--accent-light);
position: fixed; top: 0; left: 0; right: 0; z-index: 1000;
backdrop-filter: blur(10px);
}

.header-logo { display: flex; align-items: center; gap: 10px; }
.header-logo span { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; color: var(--text-dark); font-weight: 600; text-transform: uppercase; letter-spacing: 2px;}

/* 3 Dots Menu */
.header-menu { position: relative; }
.header-menu .menu-btn { color: var(--text-dark); font-size: 1.5rem; cursor: pointer; background: none; border: none; outline: none; padding: 5px; }
.dropdown-content {
display: none; position: absolute; right: 0; top: 40px; background-color: var(--card-bg); min-width: 200px;
box-shadow: 0px 8px 20px rgba(0,0,0,0.1); z-index: 2000; border-radius: 4px; border: 1px solid var(--accent-light); overflow: hidden;
}
.dropdown-content.show { display: block; }
.dropdown-content button {
width: 100%; text-align: left; background: none; border: none; color: var(--text-dark);
padding: 15px 20px; font-size: 0.95rem; cursor: pointer; font-family: 'Montserrat', sans-serif; transition: background 0.3s;
}
.dropdown-content button:hover { background-color: var(--accent-light); color: var(--accent-copper); }

/* --- HERO SECTION --- */
.hero {
padding: 160px 5% 100px;
background: linear-gradient(rgba(44, 42, 41, 0.6), rgba(44, 42, 41, 0.7)), url('https://images.unsplash.com/photo-1544148103-0773bf10d330?q=80&w=2000&auto=format&fit=crop') no-repeat center center;
background-size: cover; background-attachment: fixed; text-align: center; color: white;
}
.hero h3 { font-size: 1.2rem; letter-spacing: 4px; margin-bottom: 15px; text-transform: uppercase; font-family: 'Montserrat', sans-serif; font-weight: 300;}
.hero h1 { font-size: 4.5rem; font-style: italic; margin-bottom: 20px; font-weight: 400;}
.rating { font-size: 1.1rem; margin-bottom: 30px; }
.rating a { color: white; text-decoration: none; transition: 0.3s; }
.rating a:hover { color: var(--accent-copper); }
.rating i { color: var(--accent-copper); }
.order-btn-hero { background-color: var(--accent-copper); color: white; padding: 16px 45px; font-size: 1.1rem; border: none; border-radius: 2px; cursor: pointer; text-transform: uppercase; letter-spacing: 1px; transition: all 0.3s ease; margin: 5px; }
.order-btn-hero:hover { background-color: #9c602a; transform: translateY(-3px); }

/* --- INFO CARDS --- */
.info-section { max-width: 1100px; margin: -50px auto 50px; padding: 0 20px; display: flex; flex-wrap: wrap; gap: 20px; justify-content: center; position: relative; z-index: 10; }
.info-card { background: var(--card-bg); border: 1px solid var(--accent-light); box-shadow: 0 10px 30px rgba(0,0,0,0.05); padding: 30px; border-radius: 4px; width: 320px; cursor: pointer; transition: all 0.3s ease; text-align: center;}
.info-card:hover { transform: translateY(-5px); border-color: var(--accent-copper); }
.info-card i { font-size: 2rem; color: var(--accent-copper); margin-bottom: 15px; }
.info-card h3 { font-size: 1.5rem; margin-bottom: 10px; }
.info-card p { font-size: 0.9rem; color: #666; line-height: 1.5;}

.timing-details { max-height: 0; overflow: hidden; transition: max-height 0.4s ease; font-size: 0.85rem; color: #555; text-align: left;}
.info-card.active .timing-details { max-height: 350px; margin-top: 15px; border-top: 1px solid var(--accent-light); padding-top: 15px; }
.day-row { display: flex; justify-content: space-between; margin-bottom: 8px; border-bottom: 1px dashed #eee; padding-bottom: 4px;}

/* --- HIGHLIGHTS --- */
.menu-gallery { max-width: 1200px; margin: 60px auto; padding: 20px; text-align: center; }
.menu-gallery h2 { font-size: 3rem; color: var(--text-dark); margin-bottom: 10px; font-style: italic; }
.menu-gallery > p { color: #666; margin-bottom: 40px; letter-spacing: 1px; text-transform: uppercase; font-size: 0.9rem;}
.grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 30px; } /* Updated for max flexibility */
.menu-item-card { background: var(--card-bg); border-radius: 2px; overflow: hidden; border: 1px solid var(--accent-light); box-shadow: 0 5px 15px rgba(0,0,0,0.03);}
.menu-item-card img { width: 100%; height: 250px; object-fit: cover; transition: transform 0.6s ease; }
.menu-item-card:hover img { transform: scale(1.05); }
.item-details { padding: 25px; text-align: left; }
.item-details h4 { font-size: 1.4rem; display: flex; justify-content: space-between; margin-bottom: 10px; border-bottom: 1px solid var(--accent-light); padding-bottom: 10px;}
.item-details span { color: var(--accent-copper); font-family: 'Montserrat', sans-serif; font-size: 1.1rem; font-weight: 500;}
.item-details p { font-size: 0.9rem; color: #666; line-height: 1.6;}

/* --- REVIEWS --- */
.review-section { max-width: 1100px; margin: 40px auto 80px; padding: 20px; text-align: center; }
.review-section h2 { font-size: 3rem; font-style: italic; margin-bottom: 40px; }
.review-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 30px; }
.review-card { background: var(--card-bg); border: 1px solid var(--accent-light); padding: 30px; text-align: left; position: relative; transition: 0.3s;}
.review-card:hover { border-color: var(--accent-copper); transform: translateY(-5px); }
.review-card::before { content: '"'; font-family: serif; font-size: 4rem; color: var(--accent-light); position: absolute; top: 10px; left: 20px; line-height: 1; }
.review-stars { color: var(--accent-copper); margin-bottom: 15px; font-size: 1rem; position: relative; z-index: 2;}
.review-text { font-size: 0.95rem; color: #444; margin-bottom: 25px; line-height: 1.7; position: relative; z-index: 2;}

/* Review Author with Image */
.review-author { display: flex; align-items: center; }
.review-author img { width: 50px; height: 50px; border-radius: 50%; object-fit: cover; margin-right: 15px; border: 2px solid var(--accent-light); }
.review-author h4 { font-family: 'Montserrat', sans-serif; font-size: 1rem; margin: 0; font-weight: 600;}
.review-author span { font-size: 0.8rem; color: #888; text-transform: uppercase;}

/* Google Review Button - Strong Backend Link */
.google-review-btn { display: inline-block; margin-top: 40px; padding: 12px 30px; border: 1px solid var(--text-dark); color: var(--text-dark); text-decoration: none; text-transform: uppercase; font-family: 'Montserrat', sans-serif; font-size: 0.9rem; letter-spacing: 1px; transition: 0.3s; }
.google-review-btn:hover { background: var(--text-dark); color: white; }

/* --- FLOATING BUTTONS --- */
.floating-container { position: fixed; bottom: 30px; right: 30px; display: flex; flex-direction: column; gap: 15px; z-index: 900; }
.float-btn { width: 60px; height: 60px; border-radius: 50%; display: flex; justify-content: center; align-items: center; font-size: 1.5rem; text-decoration: none; box-shadow: 0 5px 15px rgba(0,0,0,0.2); transition: transform 0.3s; color: white;}
.float-btn:hover { transform: translateY(-5px); }
.float-btn.order { background: var(--text-dark); font-size: 1.3rem; border: none; cursor: pointer; }
.float-btn.phone { background: var(--accent-copper); }

/* --- MODALS (ORDER & RESERVATION SYSTEM) --- */
.modal-overlay { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(44, 42, 41, 0.8); backdrop-filter: blur(5px); z-index: 9999; justify-content: center; align-items: center; padding: 10px; }
.modal-content { background: var(--bg-color); width: 100%; max-width: 550px; border-radius: 4px; padding: 25px; box-shadow: 0 20px 50px rgba(0,0,0,0.3); max-height: 90vh; overflow-y: auto; position: relative; }
.modal-header { display: flex; justify-content: space-between; border-bottom: 1px solid var(--accent-copper); padding-bottom: 15px; margin-bottom: 20px; position: sticky; top: -25px; background: var(--bg-color); z-index: 10; padding-top: 25px;}
.modal-header h2 { font-size: 2rem; font-style: italic;}
.close-btn { color: #a00; cursor: pointer; font-size: 1.5rem; transition: color 0.3s;}
.close-btn:hover { color: red; }

.input-field, .table-select { width: 100%; padding: 14px; background: var(--card-bg); color: var(--text-dark); border: 1px solid #ddd; border-radius: 2px; font-size: 1rem; font-family: 'Montserrat'; margin-bottom: 15px; outline: none; box-sizing: border-box; }
.input-field:focus, .table-select:focus { border-color: var(--accent-copper); }

.category-title { color: var(--accent-copper); font-size: 1.8rem; border-bottom: 1px solid var(--accent-light); padding-bottom: 5px; margin: 25px 0 15px; font-style: italic;}
.menu-list-container { max-height: 40vh; overflow-y: auto; padding-right: 5px; }
.menu-list-container::-webkit-scrollbar { width: 5px; }
.menu-list-container::-webkit-scrollbar-thumb { background: var(--accent-copper); border-radius: 10px; }

.menu-row { display: flex; justify-content: space-between; align-items: center; background: var(--card-bg); padding: 15px; border: 1px solid #eee; margin-bottom: 10px; transition: border 0.3s; gap: 10px; }
.menu-row:hover { border-color: var(--accent-copper); }
.menu-row h4 { font-family: 'Montserrat', sans-serif; font-size: 1rem; font-weight: 500; margin-bottom: 5px; }
.add-btn { background: var(--bg-color); color: var(--accent-copper); border: 1px solid var(--accent-copper); padding: 8px 15px; cursor: pointer; font-family: 'Montserrat'; font-weight: 600; text-transform: uppercase; font-size: 0.8rem; transition: all 0.3s; white-space: nowrap; }
.add-btn:hover { background: var(--accent-copper); color: white; }

.cart-section { margin-top: 25px; background: white; padding: 20px; border: 1px solid var(--accent-copper); }
.cart-item { display: flex; justify-content: space-between; font-size: 0.9rem; margin-bottom: 10px; color: #555; border-bottom: 1px dashed #eee; padding-bottom: 5px;}
.grand-total { font-size: 1.2rem; font-weight: 600; color: var(--text-dark); margin-top: 15px; display: flex; justify-content: space-between; padding-top: 10px;}

.confirm-btn { width: 100%; background: var(--text-dark); color: white; padding: 16px; font-size: 1rem; border: none; cursor: pointer; margin-top: 20px; font-weight: 500; text-transform: uppercase; letter-spacing: 1px; transition: background 0.3s; box-sizing: border-box; }
.confirm-btn:hover { background: #000; }

/* === MOBILE RESPONSIVE (FLEXIBLE) === */
@media (max-width: 768px) {
.hero { padding-top: 130px; padding-bottom: 60px;}
.hero h1 { font-size: 2.8rem; }
.header-logo span { font-size: 1.1rem; }
.info-card { width: 100%; max-width: 100%; margin-top: 10px;}
.info-section { margin-top: -20px; padding: 0 15px; }
.menu-gallery h2, .review-section h2 { font-size: 2.2rem; }
.floating-container { bottom: 15px; right: 15px; gap: 10px; }
.float-btn { width: 50px; height: 50px; font-size: 1.2rem; }
.modal-content { padding: 15px; width: 100%; }
.menu-row h4 { font-size: 0.9rem; }
.input-field, .table-select { padding: 12px; font-size: 16px; } /* 16px prevents iOS auto-zoom */
}
</style>
